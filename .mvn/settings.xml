<?xml version="1.0" encoding="UTF-8"?>
<!--
  Settings Maven committées — source unique de credentials GitHub Packages pour ce repo
  (CI, build Docker, dev local). Chargé automatiquement par tout mvn/mvnw via
  .mvn/maven.config ("--settings .mvn/settings.xml"), donc pas besoin de dupliquer la
  configuration server-id dans chaque workflow ou étape.

  Aucun secret en dur : les deux <server> ci-dessous s'appuient sur des variables d'env
  résolues au runtime (${env.GITHUB_ACTOR} / ${env.GITHUB_TOKEN}) — absentes, elles
  s'interpolent en chaîne vide, ce qui ne casse que les opérations qui en ont réellement
  besoin (résolution de fr.pivot:pivot-core-starter, ou "mvn deploy").
-->
<settings xmlns="http://maven.apache.org/SETTINGS/1.2.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/SETTINGS/1.2.0 https://maven.apache.org/xsd/settings-1.2.0.xsd">
    <servers>
        <!-- Publication du package de CE repo (distributionManagement, pom.xml) -->
        <server>
            <id>github</id>
            <username>${env.GITHUB_ACTOR}</username>
            <password>${env.GITHUB_TOKEN}</password>
        </server>
        <!-- EN08.3 : lecture de fr.pivot:pivot-core-starter, publié par le repo pivot-core
             (voir <repositories> dans pom.xml, id "pivot-core-packages"). -->
        <server>
            <id>pivot-core-packages</id>
            <username>${env.GITHUB_ACTOR}</username>
            <password>${env.GITHUB_TOKEN}</password>
        </server>
    </servers>
</settings>
